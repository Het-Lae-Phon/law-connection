generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

// Canonical registry of primary legislation (พ.ร.บ. / พ.ร.ก. / ประมวลกฎหมาย / รัฐธรรมนูญ).
// Rows are created both from acts published in the gazette and from acts
// referenced as parents in sub-regulation titles.
model Act {
  id        Int      @id @default(autoincrement())
  slug      String   @unique
  actType   String // พระราชบัญญัติ | พระราชบัญญัติประกอบรัฐธรรมนูญ | พระราชกำหนด | ประมวลกฎหมาย | รัฐธรรมนูญ
  shortName String // e.g. "คุ้มครองข้อมูลส่วนบุคคล"
  year      Int? // B.E. year of the base act, when known
  fullName  String // e.g. "พระราชบัญญัติคุ้มครองข้อมูลส่วนบุคคล พ.ศ. 2562"
  entries   GazetteEntry[]
  contributions Contribution[]
  sources   Source[]

  @@index([shortName])
}

// Authoritative reference for an act, contributed by the community and approved
// by a moderator: e.g. Krisdika consolidated text, OCS entry, law.go.th page,
// official English translation, regulator guidance.
model Source {
  id          Int      @id @default(autoincrement())
  actId       Int
  act         Act      @relation(fields: [actId], references: [id])
  title       String // e.g. "ฉบับปรับปรุงล่าสุด (สำนักงานคณะกรรมการกฤษฎีกา)"
  url         String
  publisher   String? // e.g. "สำนักงานคณะกรรมการกฤษฎีกา"
  contributor String?
  createdAt   DateTime @default(now())

  @@unique([actId, url])
  @@index([actId])
}

// One published gazette item (maps 1:1 to a Royal Gazette PDF).
model GazetteEntry {
  id             Int       @id @default(autoincrement())
  title          String
  publishedAt    DateTime? // null for library documents without a gazette citation
  volume         Int
  issue          String
  category       String // ราชกิจจานุเบกษา section: ก, ข, ค, ง, ง พิเศษ ...
  page           Int
  origin         String    @default("gazette") // gazette | krisdika | community
  pdfUrl         String    @unique // http(s) URL, or "thailaw:<n>" for library docs
  sourceUrl      String? // external reference page (e.g. Krisdika librarian URL)
  instrumentType String? // กฎกระทรวง | ประกาศ | ระเบียบ | ข้อบังคับ | คำสั่ง | พระราชกฤษฎีกา | ...
  isPrimary      Boolean  @default(false) // true when the entry itself is primary legislation
  isAmendment    Boolean  @default(false) // "(ฉบับที่ n)" of primary legislation
  actId          Int?
  act            Act?     @relation(fields: [actId], references: [id])
  linkSource     String? // how actId was derived: "title" | "pdf" | "community"
  verifyStatus   String   @default("machine") // machine | verified | disputed
  contributions  Contribution[]
  documentText   DocumentText?

  @@index([actId])
  @@index([instrumentType])
  @@index([publishedAt])
}

// Full text for entries that have no public document URL (Krisdika library docs).
// Kept in a separate table so the main entry table stays lean for list queries.
model DocumentText {
  entryId Int          @id
  entry   GazetteEntry @relation(fields: [entryId], references: [id])
  text    String
}

// Community input, Wikipedia-style: every change is recorded, nothing is silently
// overwritten. confirm/dispute take effect immediately (and stay auditable here);
// suggestions wait in the moderation queue.
model Contribution {
  id          Int           @id @default(autoincrement())
  type        String // confirm_link | dispute_link | comment | suggest_entry | suggest_act
  status      String        @default("pending") // pending | applied | approved | rejected
  entryId     Int?
  entry       GazetteEntry? @relation(fields: [entryId], references: [id])
  actId       Int?
  act         Act?          @relation(fields: [actId], references: [id])
  payload     String? // JSON details: reason, suggested title/url/date/act name
  comment     String?
  contributor String? // display name / affiliation (self-reported in prototype)
  createdAt   DateTime      @default(now())
  reviewedAt  DateTime?

  @@index([status])
  @@index([entryId])
  @@index([actId])
}
